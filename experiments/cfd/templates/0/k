FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 1e-6;

boundaryField
{
    inlet
    {
        type            freestream;
        freestreamValue uniform 1e-6;
    }

    outlet
    {
        type            freestream;
        freestreamValue uniform 1e-6;
    }

    wall
    {
        type            kqRWallFunction;
        value           uniform 1e-6;
    }

    topAndBottom
    {
        type            slip;
    }

    frontAndBack
    {
        type            empty;
    }
}



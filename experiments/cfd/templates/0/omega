FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 1.0;

boundaryField
{
    inlet
    {
        type            freestream;
        freestreamValue uniform 1.0;
    }

    outlet
    {
        type            freestream;
        freestreamValue uniform 1.0;
    }

    wall
    {
        type            omegaWallFunction;
        value           uniform 1.0;
    }

    topAndBottom
    {
        type            slip;
    }

    frontAndBack
    {
        type            empty;
    }
}



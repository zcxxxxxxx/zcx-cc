FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     simpleFoam;

startFrom       latestTime;
startTime       0;

stopAt          endTime;
endTime         5000;

deltaT          1;
writeControl    timeStep;
writeInterval   100;

purgeWrite      0;
writeFormat     ascii;
writePrecision  8;
writeCompression uncompressed;
timeFormat      general;
timePrecision   8;

runTimeModifiable true;

// Residual monitoring (for convergence checking)
functions
{
    residuals
    {
        type            residuals;
        libs            (fieldFunctionObjects);
        fields          (U p k omega);
        writeControl    timeStep;
        writeInterval   1;
    }

    forceCoeffs
    {
        type            forceCoeffs;
        libs            (forces);
        patches         (wall);
        rho             rhoInf;
        rhoInf          1.0;
        liftDir         (0 1 0);
        dragDir         (1 0 0);
        pitchAxis       (0 0 1);
        magUInf         1.0;
        lRef            1.0;
        Aref            1.0;
        writeControl    timeStep;
        writeInterval   100;
    }
}


